generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  // Login Google (OAuth): sub dari ID token. Akun email/password tetap berdampingan.
  googleId         String?  @unique
  role             String   @default("user")
  department       String?
  position         String?
  // Status akademik/karier (menggantikan fokus "pekerja"): siswa_smk | mahasiswa | lulusan_smk | lulusan_s1
  academicStatus   String?
  education        String?
  certifications   String   @default("[]")
  experienceYears  Int      @default(0)
  currentKkniLevel Int?
  targetKkniLevel  Int?
  // Foto profil (data URI base64, di-resize kecil di klien). Kustomisasi profil.
  avatarUrl        String?
  // Preferensi tampilan tersimpan per-akun (#9). NULLABLE: null = belum diset eksplisit →
  // pakai nilai klien/default (jangan menimpa user lama). themeMode: light|dark; accent: key ACCENTS (klien).
  themeMode        String?
  accent           String?
  readinessScore   Int      @default(0)
  status           String   @default("not_ready")
  // Kompetensi SKKNI yang dipilih user sebagai target/patokan semua fitur (referensi ke SkkniDocument.id).
  chosenSkkniId    String?
  chosenSkkniTitle String?
  // Profesi/jabatan yang ditargetkan user (acuan Learning Path AI, mis. "Video Editor Profesional").
  targetRole       String?
  // Ringkasan metadata hasil ekstraksi CV terakhir (JSON: education, certifications, skills, experienceYears, dst).
  cvMeta           String   @default("{}")
  cvFileName       String?
  cvUploadedAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempts        ExamAttempt[]
  assessments     SkillAssessment[]
  recommendations Recommendation[]
  notifications   Notification[]
  requests        Request[]
  auditLogs       AuditLog[]
  wallet          CoinWallet?
  coinTx          CoinTransaction[]
  redemptions     ShopRedemption[]
  missions        DailyMission[]
  quizLogs        DailyQuizLog[]
  certificates    Certificate[]
  jobs            Job[]
  applications    JobApplication[]
  learningPlan    LearningPlan[]
  unitProgress    UnitProgress[]
  evidence        ExternalEvidence[]
  skillClaims     SkillClaim[]
}

// ── Bukti kompetensi EKSTERNAL (poin plus untuk menembus cap bobot kompetensi) ──
// Sertifikasi resmi (BNSP/nasional/internasional — BUKAN ujian kita), portofolio,
// pengalaman kerja, pelatihan/webinar. Diverifikasi AI (plausibilitas + relevansi +
// level yang diimplikasikan). Menaikkan rank DI ATAS cap ujian, tapi tetap butuh
// koroborasi ujian (headroom terbatas di rankcalc).
model ExternalEvidence {
  id                String   @id @default(cuid())
  userId            String
  type              String   // certification | portfolio | experience | training
  title             String
  issuer            String?
  description       String?
  url               String?
  relatedCompetency String?
  credibility       Int      @default(0)  // 0-100 (penilaian AI)
  rankImplied       Int      @default(0)  // 1-9 level yang diimplikasikan
  verdict           String?              // ringkas alasan AI
  status            String   @default("pending") // pending | verified | rejected
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// ── Riwayat ujian unit (review ala Quizizz) ──────────────────────────────────
// Tersimpan SETELAH submit: soal + jawaban user + jawaban benar (MC) + feedback AI,
// agar user bisa mempelajari kembali kesalahannya kapan saja.
model UnitExamReview {
  id        String   @id @default(cuid())
  userId    String
  unitCode  String
  unitTitle String
  score     Int
  passed    Boolean  @default(false)
  breakdown String   // JSON: [{question,type,options,userAnswer,correctAnswer,isCorrect,score,feedback}]
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ── Klaim skill dari CV/Portofolio (Peta Posisi #5) ──────────────────────────
// CV/portofolio HANYA bisa "mengklaim" penguasaan skill (dideteksi AI). Klaim ini
// TIDAK memvalidasi kompetensi — validasi hanya dari LULUS UJIAN proyek ini.
// `validated` diturunkan runtime (bukan disimpan) dari SkillAssessment/Certificate.
model SkillClaim {
  id         String   @id @default(cuid())
  userId     String
  jobId      String?              // konteks posisi (opsional)
  skill      String               // nama skill/kompetensi yang diklaim
  source     String               // cv | portfolio
  detail     String?              // deskripsi portofolio / tautan
  aiDetected Boolean  @default(false) // AI menemukan buktinya di CV/portofolio?
  aiNote     String?              // ringkas alasan AI
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, jobId, skill])
  @@index([userId])
}

// ── Learning Path AI (satu rencana aktif per user) ───────────────────────────
// plan = JSON hasil AI: { aiCheck, steps[] } dengan progress tersimpan per-step.
// Disusun dari hasil ujian (gap) + kompetensi SKKNI yang dipilih + profesi target.
model LearningPlan {
  id          String   @id @default(cuid())
  userId      String
  // Kompetensi SKKNI aktif saat rencana disusun — rencana DIBEDAKAN per kompetensi:
  // ganti kompetensi = rencana baru (mulai dari 0); kembali ke kompetensi lama = rencana lamanya pulih.
  docId       String?
  targetRole  String?
  plan        String   @default("{}") // JSON { aiCheck:{...}, steps:[{id,order,title,objective,why,difficulty,competencyRef,estEffort,courseQuery,progress}] }
  source      String   @default("ai") // ai | fallback
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, docId])
}

// ── Misi harian (3 tugas → klaim koin) ───────────────────────────────────────
model DailyMission {
  id        String   @id @default(cuid())
  userId    String
  day       String                 // YYYY-MM-DD
  tasks     String   @default("{}") // JSON { taskKey: true }
  claimed   Boolean  @default(false)
  claimedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, day])
}

// Log soal Course Harian — simpan agar soal hari berikutnya tidak berulang (±5 hari).
model DailyQuizLog {
  id             String   @id @default(cuid())
  userId         String
  day            String                 // YYYY-MM-DD
  docId          String?                // dokumen SKKNI (kompetensi aktif) — course harian dibedakan per kompetensi & per akun
  competencyCode String?
  questions      String   @default("[]") // JSON [{q, options[], answerKey}]
  score          Int?
  total          Int?
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, day, docId])
  @@index([userId])
}

// Sertifikat kompetensi — terbit saat lulus ujian/tes course.
model Certificate {
  id             String   @id @default(cuid())
  userId         String
  competencyCode String
  name           String
  kkniLevel      Int?
  score          Int      @default(0)
  source         String   @default("exam") // exam | course
  issuedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, competencyCode, source])
  @@index([userId])
}

// ── Job Board (lowongan pemetaan talenta) ────────────────────────────────────
model Job {
  id             String   @id @default(cuid())
  postedById     String
  postedByName   String
  company        String?
  title          String
  description    String?
  department     String?
  location       String?
  kkniLevel      Int      @default(1)
  skills         String   @default("[]") // JSON array of skill names
  minExperience  Int      @default(0)
  certifications String   @default("[]") // JSON array of cert/competency names
  modules        String   @default("[]") // JSON array {title, url} — modul belajar untuk memenuhi posisi
  status         String   @default("open") // open | closed
  createdAt      DateTime @default(now())

  postedBy     User             @relation(fields: [postedById], references: [id])
  applications JobApplication[]
}

model JobApplication {
  id         String   @id @default(cuid())
  jobId      String
  userId     String
  matchScore Int      @default(0)
  status     String   @default("applied") // applied | reviewed | rejected | accepted
  createdAt  DateTime @default(now())

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

// Konfigurasi sederhana key→value (mis. pengaturan AvatarEdu oleh admin).
model AppSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// ── Gamifikasi: dompet Koin Talenta ──────────────────────────────────────────
model CoinWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  streak    Int      @default(0)  // hari berturut klaim login harian
  lastClaim String?               // tanggal klaim login terakhir (YYYY-MM-DD)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// Buku besar transaksi koin. refType+refId dipakai untuk reward sekali-bayar (idempoten).
model CoinTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int                   // + earn / - spend
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, refType, refId])
  @@index([userId])
}

// Penukaran/unlock kelas premium di Toko dengan koin.
model ShopRedemption {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemName  String
  cost      Int
  code      String
  status    String   @default("aktif")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model KkniLevel {
  id               String @id @default(cuid())
  level            Int    @unique
  title            String
  educationMapping String
  jobGroup         String
  descriptors      String
}

// ── Katalog SKKNI (cache dari API resmi Kemnaker) ────────────────────────────
// Ditarik SEKALI per dokumen lalu disimpan permanen. API Kemnaker dibatasi ~1 request/60dtk
// per-IP, jadi semua user dilayani dari cache lokal ini; hanya cache-miss yang menembak API.
model SkkniDocument {
  id            String   @id            // UUID dokumen dari Kemnaker (documents[].id)
  title         String
  sector        String?
  number        String?                 // nomor Kepmen (mis. "249")
  year          String?                 // tahun terbit
  numberKepmen  String?
  availability  String   @default("applied")
  unitsCached   Boolean  @default(false) // apakah unit kompetensinya sudah ditarik
  unitCount     Int      @default(0)
  fetchedAt     DateTime @default(now())
  unitsFetchedAt DateTime?
  // Bobot kesulitan kompetensi (di-klasifikasi AI) → menentukan RANK MAKSIMAL yang bisa
  // diraih dari lulus ujian kita saja. Mencegah "overcapacity" (mis. Video Editing basic
  // tak bisa Legend). Untuk melampaui cap ini butuh bukti eksternal terverifikasi.
  weightMaxRank Int?                     // 5..9 (rank maksimal via ujian)
  weightTier    String?                  // label: "Operasional" | "Teknis" | "Ahli" dst
  weightReason  String?                  // alasan singkat (transparansi)
  units         SkkniUnit[]
}

model SkkniUnit {
  id           String  @id @default(cuid())
  documentId   String
  code         String                    // kode unit (mis. "Q.86NUT00.001.1")
  title        String
  availability String  @default("applied")
  document     SkkniDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Paket soal ujian ("course") per kompetensi — di-generate AI SEKALI dari unit SKKNI lalu
// disimpan permanen sebagai LIBRARY (dipakai ulang semua user). Tes ulang mengacak urutannya.
model ExamPackage {
  id            String   @id @default(cuid())
  docId         String   @unique
  title         String
  questions     String   @default("[]") // JSON [{unitCode, unitTitle, q, options, answerKey}]
  unitCount     Int      @default(0)
  questionCount Int      @default(0)
  createdAt     DateTime @default(now())
}

// Instance ujian yang SEDANG dikerjakan user — hasil pengacakan dari ExamPackage (urutan soal
// & opsi diacak, answerKey menyesuaikan). Dihapus setelah submit → tes ulang mengacak lagi.
model SkkniExam {
  id        String   @id @default(cuid())
  userId    String
  docId     String
  questions String   @default("[]") // JSON [{unitCode, unitTitle, q, options, answerKey}] (teracak)
  createdAt DateTime @default(now())

  @@unique([userId, docId])
}

// ── Kelas & Ujian per UNIT kompetensi ────────────────────────────────────────
// Ujian jadi granular: tiap unit SKKNI diuji terpisah (jumlah soal variatif) & wajib
// menyelesaikan "kelas"-nya dulu. Materi kelas + paket soal = LIBRARY global (di-generate
// AI sekali per unit, dipakai ulang semua user). Progress belajar/unlock = per user.

// Materi kelas satu unit (AI): overview, poin kunci, contoh kasus kerja, langkah praktik.
model UnitCourse {
  id        String   @id @default(cuid())
  docId     String
  unitCode  String
  unitTitle String
  content   String   @default("{}") // JSON { overview, keyPoints[], caseExample, practiceSteps[], estMinutes }
  createdAt DateTime @default(now())

  @@unique([docId, unitCode])
  @@index([docId])
}

// Paket soal satu unit (AI, jumlah soal VARIATIF sesuai kompleksitas unit) — library.
model UnitExamPackage {
  id            String   @id @default(cuid())
  docId         String
  unitCode      String
  unitTitle     String
  questions     String   @default("[]") // JSON [{q, options[4], answerKey}]
  questionCount Int      @default(0)
  createdAt     DateTime @default(now())

  @@unique([docId, unitCode])
  @@index([docId])
}

// Progres per user per unit: kelas selesai (learned) + apakah dibuka lewat koin (bypass
// urutan/kelas → langsung ke ujian). Lulus/skor tetap dibaca dari SkillAssessment/Certificate.
model UnitProgress {
  id             String    @id @default(cuid())
  userId         String
  docId          String
  unitCode       String
  learned        Boolean   @default(false) // kelas ditandai selesai
  learnedAt      DateTime?
  unlockedByCoin Boolean   @default(false) // dibeli dgn koin (bypass gating belajar → ujian)
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, unitCode])
  @@index([userId, docId])
}

// Instance ujian 1 unit yang sedang dikerjakan user (teracak dari UnitExamPackage).
// Dihapus setelah submit → tes ulang mengacak lagi. Satu unit aktif per user.
model UnitExamInstance {
  id        String   @id @default(cuid())
  userId    String
  docId     String
  unitCode  String
  unitTitle String
  questions String   @default("[]") // JSON [{q, options, answerKey}] (teracak)
  createdAt DateTime @default(now())

  @@unique([userId, unitCode])
}

model Competency {
  id                String @id @default(cuid())
  code              String @unique
  name              String
  category          String?
  description       String?
  skkni             String?
  requiredForLevels String @default("[]")
  targetLevel       Int?
}

model MappingRule {
  id             String @id @default(cuid())
  order          Int    @unique
  conditions     String
  predictedLevel Int
  weight         Int    @default(1)
}

model ExamQuestion {
  id             String @id @default(cuid())
  competencyCode String
  kkniLevel      Int
  type           String @default("multiple_choice")
  question       String
  options        String
  answerKey      Int
  points         Int    @default(1)
}

model ExamAttempt {
  id                 String   @id @default(cuid())
  userId             String
  kkniLevel          Int
  answers            String   @default("{}")
  scorePerCompetency String   @default("{}")
  results            String   @default("[]")
  readinessScore     Int      @default(0)
  status             String   @default("not_ready")
  passed             Boolean  @default(false)
  gaps               String   @default("[]")
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SkillAssessment {
  id             String   @id @default(cuid())
  userId         String
  competencyCode String
  competencyName String?
  currentScore   Int      @default(0)
  requiredScore  Int      @default(100)
  gap            Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, competencyCode])
}

model LearningResource {
  id             String  @id @default(cuid())
  title          String
  type           String
  url            String?
  competencyCode String
  level          Int?
  provider       String?
  description    String?
  duration       String?
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  resources  String   @default("[]")
  reason     String?
  aiAnalysis String?
  progress   String   @default("todo")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Request {
  id               String   @id @default(cuid())
  fromId           String
  fromName         String
  fromEmail        String
  type             String
  payload          String   @default("{}")
  status           String   @default("pending")
  handledByAdminId String?
  notes            String?
  createdAt        DateTime @default(now())

  from User @relation(fields: [fromId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  target     String?
  meta       String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
