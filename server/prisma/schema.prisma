generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../dev.db"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             String   @default("user")
  department       String?
  position         String?
  education        String?
  certifications   String   @default("[]")
  experienceYears  Int      @default(0)
  currentKkniLevel Int?
  targetKkniLevel  Int?
  readinessScore   Int      @default(0)
  status           String   @default("not_ready")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  attempts        ExamAttempt[]
  assessments     SkillAssessment[]
  recommendations Recommendation[]
  notifications   Notification[]
  requests        Request[]
  auditLogs       AuditLog[]
  wallet          CoinWallet?
  coinTx          CoinTransaction[]
  redemptions     ShopRedemption[]
  missions        DailyMission[]
  quizLogs        DailyQuizLog[]
  certificates    Certificate[]
  jobs            Job[]
  applications    JobApplication[]
}

// ── Misi harian (3 tugas → klaim koin) ───────────────────────────────────────
model DailyMission {
  id        String   @id @default(cuid())
  userId    String
  day       String                 // YYYY-MM-DD
  tasks     String   @default("{}") // JSON { taskKey: true }
  claimed   Boolean  @default(false)
  claimedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, day])
}

// Log soal Course Harian — simpan agar soal hari berikutnya tidak berulang (±5 hari).
model DailyQuizLog {
  id             String   @id @default(cuid())
  userId         String
  day            String                 // YYYY-MM-DD
  competencyCode String?
  questions      String   @default("[]") // JSON [{q, options[], answerKey}]
  score          Int?
  total          Int?
  completed      Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, day])
  @@index([userId])
}

// Sertifikat kompetensi — terbit saat lulus ujian/tes course.
model Certificate {
  id             String   @id @default(cuid())
  userId         String
  competencyCode String
  name           String
  kkniLevel      Int?
  score          Int      @default(0)
  source         String   @default("exam") // exam | course
  issuedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, competencyCode, source])
  @@index([userId])
}

// ── Job Board (lowongan pemetaan talenta) ────────────────────────────────────
model Job {
  id             String   @id @default(cuid())
  postedById     String
  postedByName   String
  company        String?
  title          String
  description    String?
  department     String?
  location       String?
  kkniLevel      Int      @default(1)
  skills         String   @default("[]") // JSON array of skill names
  minExperience  Int      @default(0)
  certifications String   @default("[]") // JSON array of cert/competency names
  modules        String   @default("[]") // JSON array {title, url} — modul belajar untuk memenuhi posisi
  status         String   @default("open") // open | closed
  createdAt      DateTime @default(now())

  postedBy     User             @relation(fields: [postedById], references: [id])
  applications JobApplication[]
}

model JobApplication {
  id         String   @id @default(cuid())
  jobId      String
  userId     String
  matchScore Int      @default(0)
  status     String   @default("applied") // applied | reviewed | rejected | accepted
  createdAt  DateTime @default(now())

  job  Job  @relation(fields: [jobId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([jobId, userId])
}

// Konfigurasi sederhana key→value (mis. pengaturan AvatarEdu oleh admin).
model AppSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}

// ── Gamifikasi: dompet Koin Talenta ──────────────────────────────────────────
model CoinWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  streak    Int      @default(0)  // hari berturut klaim login harian
  lastClaim String?               // tanggal klaim login terakhir (YYYY-MM-DD)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// Buku besar transaksi koin. refType+refId dipakai untuk reward sekali-bayar (idempoten).
model CoinTransaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Int                   // + earn / - spend
  reason    String
  refType   String?
  refId     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, refType, refId])
  @@index([userId])
}

// Penukaran/unlock kelas premium di Toko dengan koin.
model ShopRedemption {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  itemName  String
  cost      Int
  code      String
  status    String   @default("aktif")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model KkniLevel {
  id               String @id @default(cuid())
  level            Int    @unique
  title            String
  educationMapping String
  jobGroup         String
  descriptors      String
}

model Competency {
  id                String @id @default(cuid())
  code              String @unique
  name              String
  category          String?
  description       String?
  skkni             String?
  requiredForLevels String @default("[]")
  targetLevel       Int?
}

model MappingRule {
  id             String @id @default(cuid())
  order          Int    @unique
  conditions     String
  predictedLevel Int
  weight         Int    @default(1)
}

model ExamQuestion {
  id             String @id @default(cuid())
  competencyCode String
  kkniLevel      Int
  type           String @default("multiple_choice")
  question       String
  options        String
  answerKey      Int
  points         Int    @default(1)
}

model ExamAttempt {
  id                 String   @id @default(cuid())
  userId             String
  kkniLevel          Int
  answers            String   @default("{}")
  scorePerCompetency String   @default("{}")
  results            String   @default("[]")
  readinessScore     Int      @default(0)
  status             String   @default("not_ready")
  passed             Boolean  @default(false)
  gaps               String   @default("[]")
  createdAt          DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model SkillAssessment {
  id             String   @id @default(cuid())
  userId         String
  competencyCode String
  competencyName String?
  currentScore   Int      @default(0)
  requiredScore  Int      @default(100)
  gap            Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, competencyCode])
}

model LearningResource {
  id             String  @id @default(cuid())
  title          String
  type           String
  url            String?
  competencyCode String
  level          Int?
  provider       String?
  description    String?
  duration       String?
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  resources  String   @default("[]")
  reason     String?
  aiAnalysis String?
  progress   String   @default("todo")
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Request {
  id               String   @id @default(cuid())
  fromId           String
  fromName         String
  fromEmail        String
  type             String
  payload          String   @default("{}")
  status           String   @default("pending")
  handledByAdminId String?
  notes            String?
  createdAt        DateTime @default(now())

  from User @relation(fields: [fromId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  target     String?
  meta       String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
